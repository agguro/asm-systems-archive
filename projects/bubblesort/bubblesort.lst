   232 000001DB 48895EF0                    mov        qword [rsi-datasize*2], rbx   ; and store swapped values in array
   233 000001DF 488946F8                    mov        qword [rsi-datasize], rax
   234 000001E3 49FFC1                      inc        r9                            ; increment number of swaps
   235                                  .next:
