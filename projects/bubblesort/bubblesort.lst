   173                                  .repeat:      
   174 00000142 BA00000000                  mov        rdx, FALSE                    ; isSwapped = false
   175 00000147 B901000000                  mov        rcx,1                         ; i = 1
   176 0000014C 48BE-                       mov        rsi,work_array                ; point to start of the array      
   176 0000014E [1400000000000000] 
