   192 0000017E 4883EE08                    sub        rsi,datasize                  ; adjust pointer in array     
   193 00000182 48FFC1                      inc        rcx                           ; i++
   194 00000185 4C39D1                      cmp        rcx,r10                       ; if i <= arrayLength-1
   195 00000188 7ECC                        jle        .for                          ; next comparison
   196                                  .until:
