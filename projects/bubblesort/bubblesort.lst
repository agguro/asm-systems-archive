   181 0000015D 4839D8                      cmp        rax, rbx                      ; if array[i+1] >= array[i]
   182 00000160 7D19                        jge        .next
   183 00000162 4831D8                      xor        rax, rbx                      ; then swap both values            
   184 00000165 4831C3                      xor        rbx, rax
   185 00000168 4831D8                      xor        rax, rbx
   186 0000016B 48895EF0                    mov        qword [rsi-datasize*2], rbx   ; and store swapped values in array
   187 0000016F 488946F8                    mov        qword [rsi-datasize], rax
   188 00000173 BA01000000                  mov        rdx,TRUE                      ; isSwapped = true
   189 00000178 49FFC1                      inc        r9                            ; increment number of swaps
   190                                  .next:
