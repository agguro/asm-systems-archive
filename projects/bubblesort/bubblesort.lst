   123                                  ; --- VARIANT 0: Geen optimalisatie ---
   124                                  BubbleSort0:
   125 000000D2 53                          push       rbx
   126 000000D3 51                          push       rcx
   127 000000D4 52                          push       rdx
   128 000000D5 56                          push       rsi
   129 000000D6 4D31C0                      xor        r8,r8                         ; number of iterations
   130 000000D9 4D31C9                      xor        r9,r9                         ; number of swaps
   131                                  .repeat:      
   132 000000DC BA00000000                  mov        rdx, FALSE                    ; isSwapped = false
   133 000000E1 B901000000                  mov        rcx,1                         ; i = 1
   134 000000E6 48BE-                       mov        rsi,work_array                ; point to start of the array      
   134 000000E8 [1400000000000000] 
   135                                  .for:
   136 000000F0 48AD                        lodsq                                    ; RBX = array[i]
   137 000000F2 4889C3                      mov        rbx, rax
   138 000000F5 48AD                        lodsq                                    ; RAX = array[i+1]
   139 000000F7 4839D8                      cmp        rax, rbx                      ; if array[i+1] >= array[i]
   140 000000FA 7D19                        jge        .next
   141 000000FC 4831D8                      xor        rax, rbx                      ; if less then swap both values            
   142 000000FF 4831C3                      xor        rbx, rax
   143 00000102 4831D8                      xor        rax, rbx
   144 00000105 48895EF0                    mov        qword [rsi-datasize*2], rbx   ; and store swapped values in array
   145 00000109 488946F8                    mov        qword [rsi-datasize], rax
   146 0000010D BA01000000                  mov        rdx,TRUE                      ; isSwapped = true
   147 00000112 49FFC1                      inc        r9                            ; increment number of swaps
   148                                  .next:
   149 00000115 49FFC0                      inc        r8                            ; increment number of iterations
   150 00000118 4883EE08                    sub        rsi,datasize                  ; adjust pointer in array      
   151 0000011C 48FFC1                      inc        rcx                           ; i++
   152 0000011F 4883F91D                    cmp        rcx,orig_array.length-1       ; if i <= arrayLength-1
   153 00000123 7ECB                        jle        .for                          ; next comparison
   154                                  .until:
   155 00000125 4883FA01                    cmp        rdx,TRUE                      ; if isSwapped == true
   156 00000129 74B1                        je         .repeat                       ; then repeat sort algorithm
   157 0000012B 5E                          pop        rsi
   158 0000012C 5A                          pop        rdx
   159 0000012D 59                          pop        rcx
   160 0000012E 5B                          pop        rbx
   161 0000012F C3                          ret
