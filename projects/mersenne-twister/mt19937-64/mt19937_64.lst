   318 00000353 4C21C8                      and     rax, r9
   319 00000356 488B1425[00000000]          mov     rdx, qword [mt]
   320 0000035E 4C21D2                      and     rdx, r10
   321 00000361 4809D0                      or      rax, rdx                        ; Final 'x' value assembled
   322                                      
   323 00000364 4889C2                      mov     rdx, rax
   324 00000367 48D1EA                      shr     rdx, 1
   325 0000036A 48A901000000                test    rax, 1
   326 00000370 7407                        jz      .no_matrix_a_final
   327 00000372 4881F2E91966A9              xor     rdx, MATRIX_A
