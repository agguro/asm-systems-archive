   360 000003CB 4D85DB                      test    r11, r11
   361 000003CE 740B                        jz      .flush_buffer
   362                                  .pad_loop:
   363 000003D0 48FFCF                      dec     rdi
   364 000003D3 C60720                      mov     byte [rdi], ' '                 ; Pad spaces to align rows cleanly
   365 000003D6 49FFCB                      dec     r11
   366 000003D9 75F5                        jnz     .pad_loop
   367                                  
   368                                  .flush_buffer:
   369 000003DB 488D1425[E3090000]          lea     rdx, [ascii_buf + 31]
   370 000003E3 4829FA                      sub     rdx, rdi                        ; Calculate visual buffer character length width
   371 000003E6 4889FE                      mov     rsi, rdi
   372 000003E9 BF01000000                  mov     rdi, 1                          ; stdout
   373 000003EE B801000000                  mov     rax, 1                          ; sys_write
   374 000003F3 0F05                        syscall
   375 000003F5 C3                          ret
