     1                                  ; ====================================================================
     2                                  ; Title:        Mersenne Twister 64-bit PRNG (MT19937-64)
     3                                  ; Build:        nasm -felf64 mt19937_64.asm -o mt19937_64.o
     4                                  ;               ld -s -melf_x86_64 -o mt19937_64 mt19937_64.o
     5                                  ; References:   Takuji Nishimura and Makoto Matsumoto (2004/9/29 C Version)
     6                                  ;               http://www.math.hiroshima-u.ac.jp/~m-mat/MT/emt.html
     7                                  ; ====================================================================
     8                                  
     9                                  BITS 64
    10                                  GLOBAL _start
    11                                  
    12                                  ; Algorithm Constants Definitions
    13                                  %define NN          312
    14                                  %define MM          156
    15                                  %define MATRIX_A    0xB5026F5AA96619E9
    16                                  %define UM          0xFFFFFFFF80000000
    17                                  %define LM          0x000000007FFFFFFF
    18                                  
    19                                  section .bss
    20                                      align 8
    21 00000000 <res 9C0h>                  mt:             resq    NN              ; The internal state vector array
    22 000009C0 ????????                    mti:            resd    1               ; State tracking index (32-bit int)
    23 000009C4 <res 20h>                   ascii_buf:      resb    32              ; Buffer zone for textual formatting
    24                                  
    25                                  section .data
    26                                      align 8
    27 00000000 452301000000000056-         init_array:     dq      0x12345, 0x23456, 0x34567, 0x45678
    27 00000009 340200000000006745-
    27 00000012 030000000000785604-
    27 0000001B 0000000000         
    28 00000020 0400000000000000            init_len:       dq      4
    29                                  
    30 00000028 31303030206F757470-         txt_title:      db      "1000 outputs of genrand64_int64()", 10
    30 00000031 757473206F66206765-
    30 0000003A 6E72616E6436345F69-
    30 00000043 6E74363428290A     
    31                                      .len:           equ     $-txt_title
    32                                      
    33 0000004A 20                          space:          db      " "
    34 0000004B 0A                          newline:        db      10
    35                                  
    36                                  section .text
    37                                  
    38                                  _start:
    39                                      ; 1. Initialize the internal PRNG vector engine using the array block
    40 00000000 48BF-                       mov     rdi, init_array
    40 00000002 [0000000000000000] 
    41 0000000A 488B3425[20000000]          mov     rsi, [init_len]
    42 00000012 E8F7000000                  call    init_by_array64
    43                                  
    44                                      ; 2. Print out structural presentation title banner string
    45 00000017 BF01000000                  mov     rdi, 1                          ; stdout
    46 0000001C 48BE-                       mov     rsi, txt_title
    46 0000001E [2800000000000000] 
    47 00000026 BA22000000                  mov     rdx, txt_title.len
    48 0000002B B801000000                  mov     rax, 1                          ; sys_write
    49 00000030 0F05                        syscall
    50                                  
    51                                      ; 3. Core Loop: Generate and display exactly 1000 values
    52 00000032 4D31E4                      xor     r12, r12                        ; Loop iterator index i = 0
    53                                  
    54                                  .generation_loop:
    55 00000035 E8E7010000                  call    genrand64_int64                 ; Returns 64-bit random number inside rax
    56                                      
    57                                      ; Save loop metrics before handing control to the console I/O subsystem
    58 0000003A 50                          push    rax
    59                                      
    60                                      ; Convert raw value inside RAX into an aligned ASCII output string
    61 0000003B E85F030000                  call    print_uint64
    62                                      
    63                                      ; Print space padding separator
    64 00000040 BF01000000                  mov     rdi, 1
    65 00000045 48BE-                       mov     rsi, space
    65 00000047 [4A00000000000000] 
    66 0000004F BA01000000                  mov     rdx, 1
    67 00000054 B801000000                  mov     rax, 1                          ; sys_write
    68 00000059 0F05                        syscall
    69                                  
    70                                      ; Check layout configurations: if (i % 5 == 4) print a newline element
    71 0000005B 4C89E0                      mov     rax, r12
    72 0000005E 4831D2                      xor     rdx, rdx
    73 00000061 B905000000                  mov     rcx, 5
    74 00000066 48F7F1                      div     rcx                             ; Remainder drops into RDX
    75 00000069 4883FA04                    cmp     rdx, 4
    76 0000006D 751B                        jne     .skip_newline
    77                                  
    78 0000006F BF01000000                  mov     rdi, 1
    79 00000074 48BE-                       mov     rsi, newline
    79 00000076 [4B00000000000000] 
    80 0000007E BA01000000                  mov     rdx, 1
    81 00000083 B801000000                  mov     rax, 1                          ; sys_write
    82 00000088 0F05                        syscall
    83                                  
    84                                  .skip_newline:
    85 0000008A 58                          pop     rax
    86 0000008B 49FFC4                      inc     r12
    87 0000008E 4981FCE8030000              cmp     r12, 1000
    88 00000095 7C9E                        jl      .generation_loop
    89                                  
    90                                      ; Extra structural spacer format line
    91 00000097 BF01000000                  mov     rdi, 1
    92 0000009C 48BE-                       mov     rsi, newline
    92 0000009E [4B00000000000000] 
    93 000000A6 BA01000000                  mov     rdx, 1
    94 000000AB B801000000                  mov     rax, 1
    95 000000B0 0F05                        syscall
    96                                  
    97                                      ; 4. Execution context wrap-up
    98 000000B2 BF00000000                  mov     rdi, 0                          ; safe zero status return code
    99 000000B7 B83C000000                  mov     rax, 60                         ; sys_exit
   100 000000BC 0F05                        syscall
