   103                                  ; ====================================================================
   104                                  ; Function: init_genrand64
   105                                  ; Input:    rdi = 64-bit unsigned integer seed value
   106                                  ; ====================================================================
   107                                  init_genrand64:
   108 000000BE 48893C25[00000000]          mov     qword [mt], rdi                 ; mt[0] = seed
   109 000000C6 B901000000                  mov     ecx, 1                          ; mti loop counter tracking
   110 000000CB 49B82D7F954C2DF451-         mov     r8, 6364136223846793005         ; Constant multiplier element
   110 000000D4 58                 
   111                                  
   112                                  .init_loop:
   113 000000D5 488B04CD[F8FFFFFF]          mov     rax, qword [mt + rcx*8 - 8]     ; Fetch mt[mti-1]
   114 000000DD 4889C2                      mov     rdx, rax
   115 000000E0 48C1EA3E                    shr     rdx, 62                         ; mt[mti-1] >> 62
   116 000000E4 4831D0                      xor     rax, rdx                        ; (mt[mti-1] ^ (mt[mti-1] >> 62))
   117 000000E7 490FAFC0                    imul    rax, r8                         ; Multiplied by magic constant
   118 000000EB 4801C8                      add     rax, rcx                        ; + mti
   119 000000EE 488904CD[00000000]          mov     qword [mt + rcx*8], rax         ; Store inside mt[mti]
   120                                      
   121 000000F6 48FFC1                      inc     rcx
   122 000000F9 4881F938010000              cmp     rcx, NN
   123 00000100 7CD3                        jl      .init_loop
   124                                  
   125 00000102 C70425[C0090000]38-         mov     dword [mti], NN                 ; Set global index state flag
   125 0000010A 010000             
   126 0000010D C3                          ret
   127                                  
   128                                  
   129                                  ; ====================================================================
   130                                  ; Function: init_by_array64
   131                                  ; Inputs:   rdi = init_key[] array base pointer, rsi = key_length
   132                                  ; ====================================================================
   133                                  init_by_array64:
   134 0000010E 4154                        push    r12
   135 00000110 4155                        push    r13
   136 00000112 4156                        push    r14
   137 00000114 4157                        push    r15
   138                                  
   139 00000116 4989FC                      mov     r12, rdi                        ; r12 = init_key base address
   140 00000119 4989F5                      mov     r13, rsi                        ; r13 = key_length
   141                                  
   142                                      ; Run foundational seed setup routine first
   143 0000011C BFAAD62B01                  mov     rdi, 19650218
   144 00000121 E898FFFFFF                  call    init_genrand64
   145                                  
   146 00000126 41BE01000000                mov     r14, 1                          ; i = 1
   147 0000012C 4D31FF                      xor     r15, r15                        ; j = 0
   148                                  
   149                                      ; Set loop index k limits framework: k = (NN > key_length ? NN : key_length)
   150 0000012F B938010000                  mov     rcx, NN
   151 00000134 4C39E9                      cmp     rcx, r13
   152 00000137 490F42CD                    cmovb   rcx, r13                        ; rcx = Loop limit counter 'k'
   153 0000013B 49BB853FA5310FEA9D-         mov     r11, 3935559000370003845        ; Multiplier constant setup
   153 00000144 36                 
   154                                  
   155                                  .array_pass_1:
   156 00000145 51                          push    rcx
   157 00000146 4A8B04F5[F8FFFFFF]          mov     rax, qword [mt + r14*8 - 8]     ; mt[i-1]
   158 0000014E 4889C2                      mov     rdx, rax
   159 00000151 48C1EA3E                    shr     rdx, 62
   160 00000155 4831D0                      xor     rax, rdx
   161 00000158 490FAFC3                    imul    rax, r11                        ; (...) * constant
   162 0000015C 4A3304F5[00000000]          xor     rax, qword [mt + r14*8]         ; mt[i] ^ (...)
   163 00000164 4B0304FC                    add     rax, qword [r12 + r15*8]        ; + init_key[j]
   164 00000168 4C01F8                      add     rax, r15                        ; + j
   165 0000016B 4A8904F5[00000000]          mov     qword [mt + r14*8], rax         ; Save back to mt[i]
   166                                  
   167 00000173 49FFC6                      inc     r14                             ; i++
   168 00000176 49FFC7                      inc     r15                             ; j++
   169                                      
   170 00000179 4981FE38010000              cmp     r14, NN
   171 00000180 7C16                        jl      .skip_i_reset_1
   172 00000182 488B0425[B8090000]          mov     rax, qword [mt + NN*8 - 8]
   173 0000018A 48890425[00000000]          mov     qword [mt], rax                 ; mt[0] = mt[NN-1]
   174 00000192 41BE01000000                mov     r14, 1                          ; i = 1
   175                                  .skip_i_reset_1:
   176                                  
   177 00000198 4D39EF                      cmp     r15, r13
   178 0000019B 7C03                        jl      .skip_j_reset_1
   179 0000019D 4D31FF                      xor     r15, r15                        ; j = 0
   180                                  .skip_j_reset_1:
   181 000001A0 59                          pop     rcx
   182 000001A1 48FFC9                      dec     rcx
   183 000001A4 759F                        jnz     .array_pass_1
   184                                  
   185                                      ; Secondary Non-linear Pass Implementation
   186 000001A6 B937010000                  mov     rcx, NN - 1                     ; k = NN - 1
   187 000001AB 49BBFDB0B087E62EBB-         mov     r11, 2862933555777941757        ; New multiplier constant factor
   187 000001B4 27                 
   188                                  
   189                                  .array_pass_2:
   190 000001B5 51                          push    rcx
   191 000001B6 4A8B04F5[F8FFFFFF]          mov     rax, qword [mt + r14*8 - 8]     ; mt[i-1]
   192 000001BE 4889C2                      mov     rdx, rax
   193 000001C1 48C1EA3E                    shr     rdx, 62
   194 000001C5 4831D0                      xor     rax, rdx
   195 000001C8 490FAFC3                    imul    rax, r11
   196 000001CC 4A3304F5[00000000]          xor     rax, qword [mt + r14*8]
   197 000001D4 4C29F0                      sub     rax, r14                        ; - i
   198 000001D7 4A8904F5[00000000]          mov     qword [mt + r14*8], rax
   199                                  
   200 000001DF 49FFC6                      inc     r14                             ; i++
   201 000001E2 4981FE38010000              cmp     r14, NN
   202 000001E9 7C16                        jl      .skip_i_reset_2
   203 000001EB 488B0425[B8090000]          mov     rax, qword [mt + NN*8 - 8]
   204 000001F3 48890425[00000000]          mov     qword [mt], rax
   205 000001FB 41BE01000000                mov     r14, 1
   206                                  .skip_i_reset_2:
   207 00000201 59                          pop     rcx
   208 00000202 48FFC9                      dec     rcx
   209 00000205 75AE                        jnz     .array_pass_2
   210                                  
   211                                      ; Assure that the MSB bit remains locked high to guarantee safe non-zero state matrices
   212 00000207 B801000000                  mov     rax, 1
   213 0000020C 48C1E03F                    shl     rax, 63
   214 00000210 48890425[00000000]          mov     qword [mt], rax
   215                                  
   216 00000218 415F                        pop     r15
   217 0000021A 415E                        pop     r14
   218 0000021C 415D                        pop     r13
   219 0000021E 415C                        pop     r12
   220 00000220 C3                          ret
