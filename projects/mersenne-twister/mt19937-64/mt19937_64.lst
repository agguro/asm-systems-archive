   327          ******************       warning: dword data exceeds bounds [-w+number-overflow]
   328                                  .no_matrix_a_final:
   329 00000379 48331425[D8040000]          xor     rdx, qword [mt + (MM-1)*8]      ; ^ mt[MM-1]
   330 00000381 48891425[B8090000]          mov     qword [mt + (NN-1)*8], rdx
   331                                  
