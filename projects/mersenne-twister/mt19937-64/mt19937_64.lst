   338                                  ; Function: print_uint64
   339                                  ; Input:    rax = 64-bit integer payload value to print to screen
   340                                  ; ====================================================================
   341                                  print_uint64:
   342 0000039F 488D3C25[E3090000]          lea     rdi, [ascii_buf + 31]
   343 000003A7 C60700                      mov     byte [rdi], 0                   ; Inject string line suffix bounds terminator
   344 000003AA B90A000000                  mov     rcx, 10                         ; Base 10 division configuration
   345                                  
   346                                      ; Explicit loop to implement aligned width output padding metrics
   347 000003AF 41BB14000000                mov     r11, 20                         ; We enforce a 20-character width space layout
   348                                  
   349                                  .conversion_loop:
   350 000003B5 4831D2                      xor     rdx, rdx
   351 000003B8 48F7F1                      div     rcx                             ; rax = quotient, rdx = remainder character numeric value
   352 000003BB 80C230                      add     dl, '0'
   353 000003BE 48FFCF                      dec     rdi
   354 000003C1 8817                        mov     [rdi], dl
   355 000003C3 49FFCB                      dec     r11
   356 000003C6 4885C0                      test    rax, rax
   357 000003C9 75EA                        jnz     .conversion_loop
   358                                  
