   227                                  genrand64_int64:
   228 00000221 448B0425[C0090000]          mov     r8d, dword [mti]
   229 00000229 4181F838010000              cmp     r8d, NN
   230 00000230 7363                        jae     .twist_required                 ; Trigger generation block if index past limit
   231                                  
   232                                  .extract_and_temper:
   233                                      movzx   r8, r8d
   233          ******************       error: invalid combination of opcode and operands
   234 00000232 4A8B04C5[00000000]          mov     rax, qword [mt + r8*8]          ; Extract value from vector indices
   235 0000023A 41FFC0                      inc     r8d
   236 0000023D 44890425[C0090000]          mov     dword [mti], r8d                ; Save back updated mti step increment
   237                                      
   238                                      ; Tempered operations sequences matrix pipeline transforms
   239 00000245 4889C2                      mov     rdx, rax
   240 00000248 48C1EA1D                    shr     rdx, 29
   241 0000024C 48B955555555555555-         mov     rcx, 0x5555555555555555
   241 00000255 55                 
   242 00000256 4821CA                      and     rdx, rcx
   243 00000259 4831D0                      xor     rax, rdx
   244                                  
   245 0000025C 4889C2                      mov     rdx, rax
   246 0000025F 48C1E211                    shl     rdx, 17
   247 00000263 48B90000A6EDFF7FD6-         mov     rcx, 0x71D67FFFEDA60000
   247 0000026C 71                 
   248 0000026D 4821CA                      and     rdx, rcx
   249 00000270 4831D0                      xor     rax, rdx
   250                                  
   251 00000273 4889C2                      mov     rdx, rax
   252 00000276 48C1E225                    shl     rdx, 37
   253 0000027A 48B900000000E0EEF7-         mov     rcx, 0xFFF7EEE000000000
   253 00000283 FF                 
   254 00000284 4821CA                      and     rdx, rcx
   255 00000287 4831D0                      xor     rax, rdx
   256                                  
   257 0000028A 4889C2                      mov     rdx, rax
   258 0000028D 48C1EA2B                    shr     rdx, 43
   259 00000291 4831D0                      xor     rax, rdx
   260 00000294 C3                          ret                                     ; Fully tempered value returned in RAX
   261                                  
   262                                  .twist_required:
   263                                      ; Verify that baseline setups have occurred, otherwise apply default seed fallback
   264 00000295 4181F839010000              cmp     r8d, NN + 1
   265 0000029C 750A                        jne     .run_twist_loop
   266 0000029E BF71150000                  mov     rdi, 5489
   267 000002A3 E816FEFFFF                  call    init_genrand64
   268                                  
   269                                  .run_twist_loop:
   270 000002A8 31C9                        xor     ecx, ecx                        ; Loop counter variable 'i' = 0
   271 000002AA 49C7C100000080              mov     r9, UM
   272 000002B1 41BAFFFFFF7F                mov     r10, LM
   273                                  
   274                                  .twist_block_1:
   275 000002B7 488B04CD[00000000]          mov     rax, qword [mt + rcx*8]
   276 000002BF 4C21C8                      and     rax, r9                         ; mt[i] & UM
   277 000002C2 488B14CD[08000000]          mov     rdx, qword [mt + rcx*8 + 8]
   278 000002CA 4C21D2                      and     rdx, r10                        ; mt[i+1] & LM
   279 000002CD 4809D0                      or      rax, rdx                        ; rax = x = (mt[i]&UM)|(mt[i+1]&LM)
   280                                      
   281 000002D0 4889C2                      mov     rdx, rax
   282 000002D3 48D1EA                      shr     rdx, 1                          ; x >> 1
   283                                      
   284                                      ; Process mag01 array mappings inline without conditional branching anomalies
   285 000002D6 48A901000000                test    rax, 1
   286 000002DC 7407                        jz      .no_matrix_a_1
   287 000002DE 4881F2E91966A9              xor     rdx, MATRIX_A
   287          ******************       warning: signed dword immediate exceeds bounds [-w+number-overflow]
   287          ******************       warning: dword data exceeds bounds [-w+number-overflow]
   288                                  .no_matrix_a_1:
   289 000002E5 483314CD[E0040000]          xor     rdx, qword [mt + rcx*8 + MM*8]  ; ^ mt[i+MM]
   290 000002ED 488914CD[00000000]          mov     qword [mt + rcx*8], rdx
   291                                      
   292 000002F5 48FFC1                      inc     rcx
   293 000002F8 4881F99C000000              cmp     rcx, NN - MM
   294 000002FF 7CB6                        jl      .twist_block_1
   295                                  
   296                                  .twist_block_2:
   297 00000301 488B04CD[00000000]          mov     rax, qword [mt + rcx*8]
   298 00000309 4C21C8                      and     rax, r9
   299 0000030C 488B14CD[08000000]          mov     rdx, qword [mt + rcx*8 + 8]
   300 00000314 4C21D2                      and     rdx, r10
   301 00000317 4809D0                      or      rax, rdx                        ; x assembled
   302                                      
   303 0000031A 4889C2                      mov     rdx, rax
   304 0000031D 48D1EA                      shr     rdx, 1
   305 00000320 48A901000000                test    rax, 1
   306 00000326 7407                        jz      .no_matrix_a_2
   307 00000328 4881F2E91966A9              xor     rdx, MATRIX_A
   307          ******************       warning: signed dword immediate exceeds bounds [-w+number-overflow]
   307          ******************       warning: dword data exceeds bounds [-w+number-overflow]
   308                                  .no_matrix_a_2:
   309 0000032F 483314CD[20FBFFFF]          xor     rdx, qword [mt + rcx*8 + (MM-NN)*8] ; ^ mt[i+(MM-NN)]
   310 00000337 488914CD[00000000]          mov     qword [mt + rcx*8], rdx
   311                                      
   312 0000033F 48FFC1                      inc     rcx
   313 00000342 4881F937010000              cmp     rcx, NN - 1
